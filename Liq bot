import json
import websocket
import requests
import time

# ===== CONFIG =====
TELEGRAM_TOKEN = "7876723121:AAFgqqnjg2wvqATtzH15xi-nkrxLkncGnm8"
CHAT_ID = "863720412_"
MIN_LIQUIDATION_USD = 100000  # alert only if liquidation > $100k
# ==================

def send_telegram(message):
    url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
    data = {
        "chat_id": CHAT_ID,
        "text": message,
        "parse_mode": "HTML"
    }
    try:
        requests.post(url, data=data, timeout=10)
    except:
        pass

def on_message(ws, message):
    data = json.loads(message)
    for event in data:
        o = event["o"]
        symbol = o["s"]
        side = o["S"]
        price = float(o["p"])
        qty = float(o["q"])
        value = price * qty

        if value < MIN_LIQUIDATION_USD:
            continue

        liq_type = "🔴 LONG LIQUIDATION" if side == "SELL" else "🟢 SHORT LIQUIDATION"

        msg = f"<b>{liq_type}</b>\n<b>Symbol:</b> {symbol}\n<b>Price:</b> {price:,.2f}\n<b>Size:</b> ${value:,.0f}"
        send_telegram(msg)

def on_error(ws, error):
    print("Error:", error)

def on_close(ws):
    print("Connection closed. Reconnecting...")
    time.sleep(5)
    start_ws()

def on_open(ws):
    print("Connected to Binance liquidation stream")

def start_ws():
    ws = websocket.WebSocketApp(
        "wss://fstream.binance.com/ws/!forceOrder@arr",
        on_open=on_open,
        on_message=on_message,
        on_error=on_error,
        on_close=on_close
    )
    ws.run_forever()

if __name__ == "__main__":
    start_ws()
